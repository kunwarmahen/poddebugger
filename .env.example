# PodDebugger configuration — copy this file to ".env" and edit.
#
#   cp .env.example .env
#
# Every value here is a DEFAULT. A variable that is already exported in your
# shell always wins over the .env file. PodDebugger searches for .env upward
# from the directory you run it in (override with PODDEBUGGER_ENV_FILE).

# --- Platform ---------------------------------------------------------------
# podman | kubernetes | openshift
PODDEBUGGER_PLATFORM=podman

# --- LLM backend (the default for every agent) ------------------------------
# anthropic | openai | ollama | llamacpp
PODDEBUGGER_LLM_PROVIDER=ollama

# Model id. Leave commented to use the provider default
# (anthropic -> claude-opus-4-7, ollama -> llama3.1, ...).
# PODDEBUGGER_LLM_MODEL=qwen3.5:9b

# Endpoint override — Azure / vLLM / a remote Ollama or llama.cpp host.
# Local defaults: ollama http://localhost:11434/v1 , llamacpp http://localhost:8080/v1
# PODDEBUGGER_LLM_BASE_URL=http://localhost:11434/v1

# --- Credentials (NOT needed for ollama / llamacpp) -------------------------
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Per-agent LLM overrides (optional) -------------------------------------
# The investigation runs nine agents (see AGENT_HARNESS.md). Each one uses the
# default LLM above unless you override it here. Override variables:
#
#   PODDEBUGGER_<ROLE>_LLM_PROVIDER
#   PODDEBUGGER_<ROLE>_LLM_MODEL
#   PODDEBUGGER_<ROLE>_LLM_BASE_URL
#
# ROLE is one of: SCOUT PLANNER COORDINATOR ANALYST PROBER
#                 VERIFIER AUDITOR ADJUDICATOR REPORTER
#
# Tip: a common setup is a cheap/fast local model for the routine agents and a
# stronger model for the judgement-critical ones (Verifier, Adjudicator,
# Reporter). Example — default everything to local Ollama, but send the three
# critical agents to Claude:
#
# PODDEBUGGER_VERIFIER_LLM_PROVIDER=anthropic
# PODDEBUGGER_VERIFIER_LLM_MODEL=claude-opus-4-7
# PODDEBUGGER_ADJUDICATOR_LLM_PROVIDER=anthropic
# PODDEBUGGER_ADJUDICATOR_LLM_MODEL=claude-opus-4-7
# PODDEBUGGER_REPORTER_LLM_PROVIDER=anthropic
# PODDEBUGGER_REPORTER_LLM_MODEL=claude-opus-4-7
#
# Overriding only the MODEL keeps the default provider. Overriding the PROVIDER
# resets the model to that provider's default unless you also set the MODEL.

# --- Custom agents (optional) -----------------------------------------------
# The scaffold is extensible (HLD §14 / AGENT_HARNESS.md). Comma-separated list
# of dotted Python paths to your own ActionAgent or HookAgent subclasses; they
# are imported at engine startup and join the team alongside the built-ins.
# A bad path is logged to stderr and skipped — never fatal. Per-agent LLM
# routing works for custom agents too (use their `name` for the role).
#
# Example — add a MetricsAgent and a RunbookAgent from your own package:
# PODDEBUGGER_EXTRA_AGENTS=mypkg.metrics.MetricsAgent,mypkg.runbooks.RunbookAgent
#
# A copy-and-customize template lives at examples/custom_agent.py.

# --- Collection -------------------------------------------------------------
# Number of log lines collected from the workload.
PODDEBUGGER_LOG_LINES=200

# --- Remediation ------------------------------------------------------------
# SuggestOnly | ApproveRequired | AutoRemediate  (operator guardrail mode)
PODDEBUGGER_REMEDIATION_MODE=SuggestOnly
